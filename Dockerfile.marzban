# ===========================================
# Marzban Custom Dockerfile
# ===========================================

FROM gozargah/marzban:latest

# Устанавливаем sqlite3
RUN apt-get update && apt-get install -y sqlite3 && rm -rf /var/lib/apt/lists/*

# Копируем скрипт запуска
COPY marzban-start.sh /usr/local/bin/marzban-start.sh
RUN chmod +x /usr/local/bin/marzban-start.sh

# Запускаем скрипт вместо стандартного CMD
ENTRYPOINT ["/usr/local/bin/marzban-start.sh"]
