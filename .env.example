# ===========================================
# VPN Bot Project - Environment Variables Example
# ===========================================
# СКОПИРУЙТЕ этот файл в .env и заполните реальными значениями
# cp .env.example .env
#
# ВАЖНО: Никогда не коммитьте .env в git!

# ===========================================
# PostgreSQL Database
# ===========================================
# Используйте сложные пароли (минимум 16 символов)
POSTGRES_DB=vpn_bot_db
POSTGRES_USER=vpn_bot_user
POSTGRES_PASSWORD=GENERATE_SECURE_PASSWORD_HERE

# PgBouncer
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@pgbouncer:5432/${POSTGRES_DB}
POOL_MODE=transaction
MAX_CLIENT_CONN=1000
DEFAULT_POOL_SIZE=50
ADMIN_USERS=${POSTGRES_USER}
AUTH_TYPE=scram-sha-256
IGNORE_STARTUP_PARAMETERS=extra_float_digits

# ===========================================
# Backend (Flask) - SECURITY CRITICAL
# ===========================================
# Сгенерируйте случайный SECRET_KEY (минимум 32 символа)
# Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_SECRET_KEY_HERE
PORT=8080

# CORS Origins (список допустимых источников)
# Для Docker: http://backend:8080,http://bot:8080
# Для production: https://yourdomain.com
CORS_ORIGINS=http://backend:8080,http://bot:8080,http://localhost:8080

# Rate Limiting
# По умолчанию: memory:// (достаточно для 1 инстанса backend)
# Для production с несколькими инстансами: redis://redis:6379
RATELIMIT_STORAGE_URL=memory://

# YooKassa Payment
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here
YOOKASSA_TEST_MODE=true
YOOKASSA_RETURN_URL=https://yourdomain.com/payment-success

# ===========================================
# Marzban (V2Ray/Trojan/Reality) - SECURITY CRITICAL
# ===========================================
MARZBAN_URL=http://127.0.0.1:8000
MARZBAN_ADMIN=admin
# Используйте сложный пароль!
MARZBAN_PASSWORD=GENERATE_SECURE_PASSWORD_HERE

# ===========================================
# Bot (Telegram) - SECURITY CRITICAL
# ===========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
BACKEND_URL=http://backend:8080
ADMIN_USER_IDS=your_telegram_user_id
MINI_APP_URL=https://vpvks.ru/miniapp
CHANNEL_URL=https://t.me/vpvks_news
