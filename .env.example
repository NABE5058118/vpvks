# ===========================================
# Telegram Bot
# ===========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ===========================================
# Backend Configuration
# ===========================================
BACKEND_URL=http://vpn_backend:8080
DATABASE_URL=postgresql://vpn_bot_user:vp62RofV5h@vpn_pgbouncer:5432/vpn_bot_db

# ===========================================
# Mini App
# ===========================================
MINI_APP_URL=https://vpvks.ru/miniapp

# ===========================================
# Admin User IDs (comma-separated)
# ===========================================
ADMIN_USER_IDS=123456789,987654321

# ===========================================
# Channels (Telegram)
# ===========================================
CHANNEL_NEWS_URL=https://t.me/vpvks_news
CHANNEL_WIN_MAC_URL=https://t.me/vpvkspc
CHANNEL_ANDROID_IOS_URL=https://t.me/VPVKSinstr

# ===========================================
# YooKassa Payment
# ===========================================
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_TEST_MODE=true
YOOKASSA_RETURN_URL=https://t.me/yourbot?start=payment_success

# ===========================================
# Marzban VPN Server
# ===========================================
MARZBAN_URL=http://marzban:8000
MARZBAN_PUBLIC_URL=https://vpvks.ru
MARZBAN_ADMIN=admin
MARZBAN_PASSWORD=your_marzban_password

# ===========================================
# PostgreSQL
# ===========================================
POSTGRES_DB=vpn_bot_db
POSTGRES_USER=vpn_bot_user
POSTGRES_PASSWORD=vp62RofV5h
PGDATA=/var/lib/postgresql/data/pgdata

# ===========================================
# PgBouncer
# ===========================================
POOL_MODE=transaction
MAX_CLIENT_CONN=100
DEFAULT_POOL_SIZE=20
ADMIN_USERS=vpn_bot_user
AUTH_TYPE=md5
IGNORE_STARTUP_PARAMETERS=extra_float_digits

# ===========================================
# Flask Backend
# ===========================================
PORT=8080
SECRET_KEY=your_secret_key_here_32_chars_min
CORS_ORIGINS=http://backend:8080,http://bot:8080
